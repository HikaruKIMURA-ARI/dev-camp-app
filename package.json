{
  "name": "devcamp",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run prepare:assets && bun run --hot src/index.tsx",
    "start": "bun run src/index.tsx",
    "db:gen": "drizzle-kit generate",
    "db:mig": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "bun test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "oxlint --fix",
    "fmt": "oxfmt",
    "typecheck": "tsc --noEmit",
    "prepare:assets": "mkdir -p public/static && cp node_modules/htmx.org/dist/htmx.min.js public/static/ && cp node_modules/alpinejs/dist/cdn.min.js public/static/alpine.min.js && cp node_modules/@picocss/pico/css/pico.min.css public/static/pico.min.css && cp public/app.css public/static/app.css && cp public/favicon.svg public/static/favicon.svg && cp public/favicon.svg public/favicon.ico",
    "dev:worker": "bun run prepare:assets && wrangler dev",
    "deploy": "bun run prepare:assets && wrangler deploy"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@hono/zod-validator": "^0.7.6",
    "@libsql/client": "^0.14.0",
    "@picocss/pico": "^2.1.1",
    "alpinejs": "^3.15.12",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.14",
    "htmx.org": "^2.0.10",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/bun": "latest",
    "@types/node": "^25.6.0",
    "drizzle-kit": "^0.31.10",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "typescript": "^5.6.3",
    "wrangler": "^4.20.0"
  }
}
