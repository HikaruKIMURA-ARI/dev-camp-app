# ローカル開発: file: スキームでローカル SQLite を使う
TURSO_DATABASE_URL=file:local.db
# TURSO_AUTH_TOKEN=

# 本番 (Turso) 例:
# TURSO_DATABASE_URL=libsql://<your-db>-<org>.turso.io
# TURSO_AUTH_TOKEN=<your-auth-token>

# Gemini API（参加者カード生成）。未設定でもアプリは起動し、常に Tier 3（最低限デフォルト）で稼働する。
# 取得方法は .kiro/specs/tyousei-ph2/design.md「Gemini API セットアップ手順」を参照。
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_TIMEOUT_MS=4000
# GEMINI_TEMPERATURE=0.9
# GEMINI_MAX_OUTPUT_TOKENS=256
# 起動時の疎通確認をオプトインで有効化する（1 = 有効）。未設定なら実 API リクエストを発生させない。
# GEMINI_VERIFY_ON_BOOT=0

# Cloudflare Workers（wrangler）では wrangler.toml の SKIP_DB_MIGRATE=1 のため起動時 migrate しない。
# デプロイ前に本番 DB へ: TURSO_DATABASE_URL=... TURSO_AUTH_TOKEN=... bun db:mig
# ローカル wrangler dev 用: cp .dev.vars.example .dev.vars
